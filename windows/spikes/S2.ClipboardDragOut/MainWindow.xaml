<Window x:Class="S2.ClipboardDragOut.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="S2 Clipboard Drag Out"
        Width="720"
        Height="520"
        Background="#111827">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Foreground="#F8FAFC" FontSize="20" FontWeight="SemiBold" Text="Clipboard listener + drag out spike" />
            <TextBlock x:Name="StatusText" Foreground="#CBD5E1" Margin="0,6,0,12" TextWrapping="Wrap" />
        </StackPanel>
        <ListBox x:Name="HistoryList"
                 Grid.Row="1"
                 Background="#0B1120"
                 Foreground="#E2E8F0"
                 BorderBrush="#334155"
                 DisplayMemberPath="DisplayText" />
        <WrapPanel Grid.Row="2" Margin="0,14,0,0">
            <Button x:Name="SeedTextButton" Content="Seed Text" Margin="0,0,8,0" Padding="12,6" />
            <Button x:Name="SeedImageButton" Content="Seed Image" Margin="0,0,8,0" Padding="12,6" />
            <Button x:Name="DragLatestButton" Content="Drag Latest Item" Margin="0,0,8,0" Padding="12,6" />
            <Button x:Name="ClearButton" Content="Clear In-Memory History" Padding="12,6" />
        </WrapPanel>
    </Grid>
</Window>
